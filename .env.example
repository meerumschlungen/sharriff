# Sharriff Environment Variables
# Copy this file to .env and customize for your setup

# === API Keys for *arr Instances ===
# Note: These are just examples. You can use any variable names you like
# and reference them in your config.yaml using ${VARIABLE_NAME} syntax.
# Variable interpolation works for any config field, not just API keys.

LIDARR_API_KEY=your_lidarr_api_key_here
SONARR_API_KEY=your_sonarr_api_key_here
RADARR_API_KEY=your_radarr_api_key_here

# === Logging Configuration ===
# Log format: 'pretty' for human-readable, 'json' for structured logs
# Default: 'pretty' in development, 'json' in production
# LOG_FORMAT=pretty

# Log level: 'debug', 'info', 'warn', 'error'
# Default: 'debug' in development, 'info' in production
# LOG_LEVEL=info

# Timezone for log timestamps (only affects 'pretty' format)
# Default: 'UTC'
# Examples: 'America/New_York', 'Europe/Berlin', 'Asia/Tokyo'
# TZ=UTC

# === Application Configuration ===
# Path to YAML configuration file (required)
# SHARRIFF_CONFIG_FILE=config.yaml
