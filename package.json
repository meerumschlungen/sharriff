{
  "name": "sharriff",
  "version": "0.1.0",
  "description": "TypeScript-based orchestration service for *arr clients",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "dev": "node --env-file=.env --import tsx src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check": "npm run type-check && npm run lint && npm run format:check && npm test"
  },
  "keywords": [
    "radarr",
    "sonarr",
    "lidarr",
    "automation",
    "orchestration"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meerumschlungen/sharriff.git"
  },
  "bugs": {
    "url": "https://github.com/meerumschlungen/sharriff/issues"
  },
  "homepage": "https://github.com/meerumschlungen/sharriff#readme",
  "dependencies": {
    "async-mutex": "^0.5.0",
    "axios": "^1.15.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "4.1.4",
    "eslint": "10.2.0",
    "globals": "17.5.0",
    "prettier": "3.8.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
